---
import type { KnowledgeGraph, KnowledgeGraphRelation } from '../lib/knowledge-graph';

interface Props {
  graph: KnowledgeGraph;
}

const { graph } = Astro.props;
const pages = graph.nodes.filter((node) => !node.catalog).sort((a, b) => a.title.localeCompare(b.title));
const pageIds = new Set(pages.map((page) => page.id));
const edges = graph.edges.filter((edge) => pageIds.has(edge.source) && pageIds.has(edge.target));

const relationOrder: KnowledgeGraphRelation[] = ['related', 'parent', 'source', 'mention'];
const relationLabels: Record<KnowledgeGraphRelation, string> = {
  related: 'Related',
  parent: 'Hierarchy',
  source: 'Sources',
  mention: 'Mentions',
};
const relationCounts = new Map(relationOrder.map((relation) => [relation, 0]));
for (const edge of edges) {
  relationCounts.set(edge.relation, (relationCounts.get(edge.relation) ?? 0) + 1);
}
const availableRelations = relationOrder.filter((relation) => (relationCounts.get(relation) ?? 0) > 0);

function titleCase(value: string) {
  return value
    .split(/[-_/]/)
    .filter(Boolean)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');
}

const serializedGraph = JSON.stringify(graph)
  .replace(/</g, '\\u003c')
  .replace(new RegExp('\\u2028', 'g'), '\\u2028')
  .replace(new RegExp('\\u2029', 'g'), '\\u2029');
---

<section class="knowledge-graph" data-knowledge-graph aria-labelledby="knowledge-graph-title">
  <header class="knowledge-graph-header">
    <p class="knowledge-graph-eyebrow">Knowledge graph</p>
    <h1 id="knowledge-graph-title">Explore the wiki</h1>
    <p class="knowledge-graph-summary">
      {pages.length} {pages.length === 1 ? 'page' : 'pages'} clustered by type. Hover a node for its
      title, click to open the page.
    </p>
  </header>

  {pages.length > 0 ? (
    <div class="knowledge-graph-stage" data-graph-stage>
      <p class="knowledge-graph-loading">Loading graph…</p>
      <svg
        class="knowledge-graph-svg"
        data-graph-svg
        role="img"
        aria-labelledby="knowledge-graph-svg-title knowledge-graph-svg-description"
      >
        <title id="knowledge-graph-svg-title">Interactive map of wiki pages</title>
        <desc id="knowledge-graph-svg-description">
          Pages are grouped into clusters by type. Hover or focus a node to see its title, click it
          to open the page, and use the on-canvas filters to reveal more relationship layers.
        </desc>
      </svg>

      <div class="knowledge-graph-hud knowledge-graph-hud--view">
        <div class="knowledge-graph-segmented" role="group" aria-label="Graph view">
          <button type="button" data-graph-mode="whole" aria-pressed="true">Whole map</button>
          <button type="button" data-graph-mode="neighborhood" aria-pressed="false">Neighborhood</button>
        </div>
      </div>

      <div class="knowledge-graph-hud knowledge-graph-hud--relations" role="group" aria-label="Relationship filters">
        {availableRelations.map((relation) => (
          <button
            type="button"
            class={`knowledge-graph-filter knowledge-graph-filter--${relation}`}
            data-graph-relation={relation}
            aria-pressed={relation === 'related' ? 'true' : 'false'}
          >
            <i aria-hidden="true"></i>
            {relationLabels[relation]}
            <span>{relationCounts.get(relation)}</span>
          </button>
        ))}
      </div>

      <div class="knowledge-graph-hud knowledge-graph-hud--zoom" role="group" aria-label="Zoom controls">
        <button type="button" data-graph-action="zoom-out" aria-label="Zoom out">−</button>
        <button type="button" data-graph-action="fit" aria-label="Fit graph to view">Fit</button>
        <button type="button" data-graph-action="zoom-in" aria-label="Zoom in">+</button>
      </div>

      <div class="knowledge-graph-tooltip" data-graph-tooltip role="tooltip" hidden></div>
      <p class="sr-only" data-graph-status aria-live="polite"></p>
    </div>
  ) : (
    <div class="knowledge-graph-empty">No pages are available yet. Run the wiki setup or ingest skills, then refresh.</div>
  )}

  <details class="knowledge-graph-list">
    <summary>Browse the accessible page list</summary>
    <ul>
      {pages.map((page) => (
        <li>
          <a href={page.href}>{page.title}</a>
          <span class="knowledge-graph-list-kind">
            {page.category === 'source' ? 'Source' : titleCase(page.category)}
            {page.status ? ` · ${titleCase(page.status)}` : ''}
          </span>
        </li>
      ))}
    </ul>
  </details>

  <script is:inline type="application/json" class="knowledge-graph-data" set:html={serializedGraph}></script>
</section>

<script>
  import '../scripts/knowledge-graph.js';
</script>
