---
import { getEntry, render } from 'astro:content';
import KnowledgeGraph from '../components/KnowledgeGraph.astro';
import Layout from '../layouts/Layout.astro';
import { getKnowledgeGraph } from '../lib/knowledge-graph';

const graph = getKnowledgeGraph();
const entry = await getEntry('sources', 'index');
if (!entry) throw new Error('sources/index.md not found — run `npm run sync`');

const { Content } = await render(entry);
const title = entry.data.title || 'Sources Index';
---

<Layout title={title} currentSlug="index">
  <header class="doc-header home-header">
    <h1>{title}</h1>
  </header>
  <KnowledgeGraph graph={graph} />
  <article class="doc home-source-index">
    <div class="doc-body">
      <Content />
    </div>
  </article>
</Layout>
